# Prominent Experts — Environment Variables

# === Site ===
NEXT_PUBLIC_SITE_URL=https://promksa.com
NEXT_PUBLIC_GA_ID=

# === Supabase (for leads storage) ===
# Get these from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === SMTP (for contact email notifications) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your-password
CONTACT_TO_EMAIL=hello@promksa.com
CONTACT_FROM_EMAIL=noreply@promksa.com

# === Admin Dashboard ===
# Set a token to protect /admin/leads
# Access via /admin/leads?token=YOUR_TOKEN or login form
ADMIN_LEADS_TOKEN=your-secret-token
